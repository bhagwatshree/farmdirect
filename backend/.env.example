# MongoDB connection string (used for local development)
MONGO_URI=

# --- AWS DocumentDB settings (used when deployed to AWS) ---
# Set to "true" to use IAM authentication with DocumentDB
# DOCDB_IAM_AUTH=true
# DOCDB_HOST=your-cluster.docdb.amazonaws.com
# DOCDB_PORT=27017
# DOCDB_USERNAME=farmdirect_admin
# DOCDB_DATABASE=farmdirect
# AWS_REGION=ap-south-1
# DOCDB_CA_PATH=/app/rds-combined-ca-bundle.pem

# JWT secret key (use a long random string in production)
JWT_SECRET=

# Node environment
NODE_ENV=development

# Server port
PORT=5000

# Email sender display name and address
EMAIL_FROM=

# Gmail SMTP settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# OpenAI API key (for chatbot)
OPENAI_API_KEY=

# Razorpay — get keys from https://dashboard.razorpay.com/app/keys (use test keys for development)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret — generated when creating a webhook in Razorpay Dashboard → Webhooks
RAZORPAY_WEBHOOK_SECRET=
