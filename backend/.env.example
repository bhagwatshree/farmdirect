# MongoDB connection string
MONGO_URI=

# JWT secret key (use a long random string in production)
JWT_SECRET=

# Node environment
NODE_ENV=development

# Server port
PORT=5000

# Email sender display name and address
EMAIL_FROM=

# Gmail SMTP settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# OpenAI API key (for chatbot)
OPENAI_API_KEY=

# Razorpay — get keys from https://dashboard.razorpay.com/app/keys (use test keys for development)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret — generated when creating a webhook in Razorpay Dashboard → Webhooks
RAZORPAY_WEBHOOK_SECRET=
